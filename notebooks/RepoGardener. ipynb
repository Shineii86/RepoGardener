   "source": [
    "#@title ⚙️ 2. Configuration & Run\n",
    "\n",
    "# =============================================================================\n",
    "#  🔧 Configuration\n",
    "# =============================================================================\n",
    "\n",
    "# Your GitHub username\n",
    "USERNAME = \"Shineii86\"  #@param {type:\"string\"}\n",
    "\n",
    "# Your Personal Access Token (classic) with 'repo' scope\n",
    "TOKEN = \"ghp_xxxxxxxxxxxxxxxxxxxx\"  #@param {type:\"string\"}\n",
    "\n",
    "# Mode: \"scan\" (report only) or \"update\" (scan and create PRs)\n",
    "MODE = \"scan\"  #@param [\"scan\", \"update\"] {type:\"string\"}\n",
    "\n",
    "# Repository filter (leave blank to scan all, or use comma-separated list)\n",
    "REPO_FILTER = \"\"  #@param {type:\"string\"}\n",
    "\n",
    "# Delay between API calls (seconds) to avoid rate limits\n",
    "ACTION_DELAY = 1  #@param {type:\"number\"}\n",
    "\n",
    "# =============================================================================\n",
    "#  🌱 Repo Gardener Core Logic\n",
    "# =============================================================================\n",
    "\n",
    "g = Github(TOKEN)\n",
    "user = g.get_user(USERNAME)\n",
    "\n",
    "def get_pypi_latest_version(package_name):\n",
    "    \"\"\"Fetch the latest version of a package from PyPI.\"\"\"\n",
    "    try:\n",
    "        url = f\"https://pypi.org/pypi/{package_name}/json\"\n",
    "        response = requests.get(url, timeout=5)\n",
    "        if response.status_code == 200:\n",
    "            return response.json()[\"info\"][\"version\"]\n",
    "    except Exception:\n",
    "        pass\n",
    "    return None\n",
    "\n",
    "def parse_requirements(content):\n",
    "    \"\"\"Parse a requirements.txt file into a dict of package -> current_version.\"\"\"\n",
    "    packages = {}\n",
    "    lines = content.split('\\n')\n",
    "    for line in lines:\n",
    "        line = line.strip()\n",
    "        if not line or line.startswith('#'):\n",
    "            continue\n",
    "        # Handle basic package specifications\n",
    "        match = re.match(r'^([a-zA-Z0-9_\\-]+)([=~<>!]+)([a-zA-Z0-9_.\\-]+)', line)\n",
    "        if match:\n",
    "            pkg, op, ver = match.groups()\n",
    "            packages[pkg.lower()] = ver\n",
    "        else:\n",
    "            # Handle packages without version spec (just name)\n",
    "            pkg_match = re.match(r'^([a-zA-Z0-9_\\-]+)', line)\n",
    "            if pkg_match:\n",
    "                packages[pkg_match.group(1).lower()] = \"latest\"\n",
    "    return packages\n",
    "\n",
    "def check_outdated_packages(packages):\n",
    "    \"\"\"Check which packages are outdated.\"\"\"\n",
    "    outdated = {}\n",
    "    for pkg, current_ver in packages.items():\n",
    "        if current_ver == \"latest\":\n",
    "            continue\n",
    "        latest = get_pypi_latest_version(pkg)\n",
    "        if latest:\n",
    "            try:\n",
    "                if version.parse(latest) > version.parse(current_ver):\n",
    "                    outdated[pkg] = {\"current\": current_ver, \"latest\": latest}\n",
    "            except:\n",
    "                # Skip if version parsing fails\n",
    "                pass\n",
    "    return outdated\n",
    "\n",
    "def get_file_content(repo, path):\n",
    "    \"\"\"Get the content of a file from a repository.\"\"\"\n",
    "    try:\n",
    "        content = repo.get_contents(path)\n",
    "        return base64.b64decode(content.content).decode('utf-8')\n",
    "    except GithubException:\n",
    "        return None\n",
    "\n",
    "def update_requirements_file(repo, path, outdated_packages, branch_name):\n",
    "    \"\"\"Update a requirements.txt file with new versions.\"\"\"\n",
    "    content = get_file_content(repo, path)\n",
    "    if not content:\n",
    "        return False\n",
    "    \n",
    "    updated = False\n",
    "    lines = content.split('\\n')\n",
    "    new_lines = []\n",
    "    \n",
    "    for line in lines:\n",
    "        stripped = line.strip()\n",
    "        if not stripped or stripped.startswith('#'):\n",
    "            new_lines.append(line)\n",
    "            continue\n",
    "        \n",
    "        match = re.match(r'^([a-zA-Z0-9_\\-]+)([=~<>!]+)([a-zA-Z0-9_.\\-]+)', stripped)\n",
    "        if match:\n",
    "            pkg, op, ver = match.groups()\n",
    "            pkg_lower = pkg.lower()\n",
    "            if pkg_lower in outdated_packages:\n",
    "                new_ver = outdated_packages[pkg_lower][\"latest\"]\n",
    "                new_line = f\"{pkg}{op}{new_ver}\"\n",
    "                new_lines.append(new_line)\n",
    "                updated = True\n",
    "            else:\n",
    "                new_lines.append(line)\n",
    "        else:\n",
    "            new_lines.append(line)\n",
    "    \n",
    "    if not updated:\n",
    "        return False\n",
    "    \n",
    "    new_content = '\\n'.join(new_lines)\n",
    "    \n",
    "    # Get the main branch SHA\n",
    "    main_branch = repo.get_branch(repo.default_branch)\n",
    "    base_sha = main_branch.commit.sha\n",
    "    \n",
    "    # Create a new branch\n",
    "    try:\n",
    "        repo.create_git_ref(f\"refs/heads/{branch_name}\", base_sha)\n",
    "    except GithubException:\n",
    "        # Branch might already exist, try to delete and recreate\n",
    "        try:\n",
    "            repo.get_git_ref(f\"heads/{branch_name}\").delete()\n",
    "            repo.create_git_ref(f\"refs/heads/{branch_name}\", base_sha)\n",
    "        except:\n",
    "            return False\n",
    "    \n",
    "    # Update the file on the new branch\n",
    "    try:\n",
    "        file = repo.get_contents(path, ref=branch_name)\n",
    "        repo.update_file(\n",
    "            path,\n",
    "            f\"🌱 Update dependencies in {path}\",\n",
    "            new_content,\n",
    "            file.sha,\n",
    "            branch=branch_name\n",
    "        )\n",
    "    except GithubException:\n",
    "        # File doesn't exist on the branch (shouldn't happen)\n",
    "        return False\n",
    "    \n",
    "    return True\n",
    "\n",
    "def create_pr(repo, branch_name, title, body):\n",
    "    \"\"\"Create a pull request.\"\"\"\n",
    "    try:\n",
    "        pr = repo.create_pull(\n",
    "            title=title,\n",
    "            body=body,\n",
    "            head=branch_name,\n",
    "            base=repo.default_branch\n",
    "        )\n",
    "        return pr\n",
    "    except GithubException as e:\n",
    "        print(f\"  ⚠️ Failed to create PR: {e}\")\n",
    "        return None\n",
    "\n",
    "# =============================================================================\n",
    "#  🚀 Main Execution\n",
    "# =============================================================================\n",
    "\n",
    "print(f\"\\n🌱 Repo Gardener for user '{USERNAME}'\")\n",
    "print(f\"Mode: {MODE.upper()}\")\n",
    "print(\"=\"*50)\n",
    "\n",
    "# Get list of repositories\n",
    "if REPO_FILTER.strip():\n",
    "    filter_list = [r.strip() for r in REPO_FILTER.split(',')]\n",
    "    repos = [repo for repo in user.get_repos() if repo.name in filter_list]\n",
    "else:\n",
    "    repos = list(user.get_repos())\n",
    "\n",
    "print(f\"📂 Found {len(repos)} repositories to scan.\\n\")\n",
    "\n",
    "scan_results = []\n",
    "\n",
    "for repo in repos:\n",
    "    print(f\"🔍 Scanning {repo.full_name}...\")\n",
    "    \n",
    "    # Skip archived or forked repos if desired (optional)\n",
    "    if repo.archived:\n",
    "        print(f\"  ⏭️ Skipping archived repository.\")\n",
    "        continue\n",
    "    \n",
    "    # Look for requirements.txt\n",
    "    req_content = get_file_content(repo, \"requirements.txt\")\n",
    "    if not req_content:\n",
    "        print(f\"  ℹ️ No requirements.txt found.\")\n",
    "        continue\n",
    "    \n",
    "    packages = parse_requirements(req_content)\n",
    "    outdated = check_outdated_packages(packages)\n",
    "    \n",
    "    if not outdated:\n",
    "        print(f\"  ✅ All dependencies are up-to-date!\")\n",
    "        continue\n",
    "    \n",
    "    print(f\"  📦 Found {len(outdated)} outdated package(s):\")\n",
    "    for pkg, versions in outdated.items():\n",
    "        print(f\"     - {pkg}: {versions['current']} → {versions['latest']}\")\n",
    "    \n",
    "    scan_results.append({\n",
    "        \"repo\": repo.full_name,\n",
    "        \"outdated\": outdated\n",
    "    })\n",
    "    \n",
    "    if MODE == \"update\":\n",
    "        branch_name = f\"repo-gardener/update-deps-{datetime.now().strftime('%Y%m%d%H%M%S')}\"\n",
    "        success = update_requirements_file(repo, \"requirements.txt\", outdated, branch_name)\n",
    "        \n",
    "        if success:\n",
    "            # Create a pull request\n",
    "            title = \"🌱 Update outdated dependencies\"\n",
    "            body = \"This PR updates the following outdated dependencies:\\n\\n\"\n",
    "            for pkg, versions in outdated.items():\n",
    "                body += f\"- `{pkg}`: {versions['current']} → {versions['latest']}\\n\"\n",
    "            body += \"\\n*This PR was automatically created by [Repo Gardener](https://github.com/Shineii86/RepoGardener).*\"\n",
    "            \n",
    "            pr = create_pr(repo, branch_name, title, body)\n",
    "            if pr:\n",
    "                print(f\"  🎉 Created PR: {pr.html_url}\")\n",
    "        else:\n",
    "            print(f\"  ❌ Failed to create update branch.\")\n",
    "    \n",
    "    time.sleep(ACTION_DELAY)\n",
    "\n",
    "print(\"\\n\" + \"=\"*50)\n",
    "\n",
    "if not scan_results:\n",
    "    print(\"✨ No outdated dependencies found! Your repositories are healthy.\")\n",
    "else:\n",
    "    print(f\"📊 Summary: Found outdated dependencies in {len(scan_results)} repository(ies).\")\n",
    "    for result in scan_results:\n",
    "        print(f\"\\n📁 {result['repo']}:\")\n",
    "        for pkg, versions in result['outdated'].items():\n",
    "            print(f\"   - {pkg}: {versions['current']} → {versions['latest']}\")\n",
    "\n",
    "print(\"\\n---\")\n",
    "print(\"🌱 Repo Gardener By [Shinei Nouzen](https://github.com/Shineii86/RepoGardener)\")\n"
   ],
